    "passport": "^0.7.0",
    "passport-discord": "^0.1.4",
    "mongoose": "^8.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "helmet": "^7.1.0",
    "axios": "^1.6.7",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "concurrently": "^8.2.2"
